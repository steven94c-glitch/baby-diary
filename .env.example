# Baby's name — shown as the site title
BABY_NAME="Baby"

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Secret token used to verify Telegram webhook calls (any random string you choose)
TELEGRAM_WEBHOOK_SECRET=

# The chat ID of the Telegram group containing you, your wife, and the bot
# (negative number, e.g. -1001234567890). Find by sending a message and visiting
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_ALLOWED_CHAT_ID=

# Comma-separated Telegram user IDs allowed to post (you and your wife)
TELEGRAM_ALLOWED_USER_IDS=

# Optional: password to view the site. Leave blank for fully public.
SITE_PASSWORD=

# Optional: subtitle under the baby's name on the homepage
TAGLINE="moments and milestones"

# Optional: rename Telegram first names to display names on the site.
# Format: "RealName1=DisplayName1,RealName2=DisplayName2"
# e.g. AUTHOR_ALIASES="Steve=Dad,Lina=Mom"
AUTHOR_ALIASES=

# Auto-set by Vercel when you enable Blob storage
BLOB_READ_WRITE_TOKEN=
